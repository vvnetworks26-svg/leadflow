{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",

    "lib": ["ES2022"],

    "types": ["node"],

    "outDir": "dist",
    "rootDir": "src",

    "strict": true,

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },

  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}