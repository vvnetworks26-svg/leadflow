# ─────────────────────────────────────────────────────────────────
# LeadFlow API — Environment Variables
# Copy this file to .env and fill in all values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
API_VERSION=1.0.0

# Database — required in production
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/leadflow?retryWrites=true&w=majority

# JWT — required in production (use long random strings, minimum 32 chars)
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info
