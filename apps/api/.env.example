# ─────────────────────────────────────────────────────────────────
# LeadFlow API — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ─────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
API_VERSION=1.0.0

# Database (not connected yet — Sprint 5.2)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/leadflow?retryWrites=true&w=majority

# Auth (not implemented yet — Sprint 5.3)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info
