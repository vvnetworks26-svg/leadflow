# ─────────────────────────────────────────────────────────────────
# LeadFlow API — Environment Variables
# Copy this file to .env and fill in all values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
API_VERSION=1.0.0

# Database — required in production
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/leadflow?retryWrites=true&w=majority

# JWT — required in production (use long random strings, minimum 32 chars)
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# AI — Gemini API key (optional; AI uses rule-based fallbacks if absent)
GEMINI_API_KEY=

# Google Calendar OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/calendar/oauth/google/callback

# Microsoft 365 OAuth (optional)
MS_CLIENT_ID=
MS_CLIENT_SECRET=

  # Communications providers (optional)
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
META_WA_PHONE_ID=
META_WA_TOKEN=

# Logging
LOG_LEVEL=info
