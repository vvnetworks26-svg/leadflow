# ─────────────────────────────────────────────────────────────────────────────
# LeadFlow — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Express API server.
# The Axios client in src/lib/apiClient.ts reads this variable.
VITE_API_URL=http://localhost:4000

# Organization slug or ID used by the anonymous chat widget.
# This is the token that identifies your organization in the public widget API
# (GET /api/v1/widget/:token/config, POST /api/v1/widget/:token/leads, etc.).
# Set this to your organization's slug (e.g. "miller-hvac") or MongoDB _id.
# The widget will work without authentication using only this value.
VITE_WIDGET_TOKEN=
