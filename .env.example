# ─────────────────────────────────────────────────────────────────────────────
# LeadFlow — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# API base URL for the backend (used by the Vite dev proxy and production fetch calls)
VITE_API_URL=http://localhost:4000

# OpenAI API key — required when the AI chat engine is wired to a real LLM
VITE_OPENAI_API_KEY=sk-...

# Google OAuth 2.0 client ID — required for Google Calendar integration (Sprint 4)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# MongoDB connection string — required when the mock API layer is replaced with a real DB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/leadflow?retryWrites=true&w=majority

# JWT signing secret — used for signing auth tokens on the Express API server
JWT_SECRET=change-me-to-a-long-random-string
